# Indemnifi — Contracts Environment Variables
# Copy this to .env and fill in real values. Never commit .env.

# Deployer private key (no 0x prefix)
PRIVATE_KEY=

# RPC URLs
UNICHAIN_RPC_URL=https://sepolia.unichain.org
REACTIVE_RPC_URL=https://lasna-rpc.rnk.dev/

# Block explorer verification
ETHERSCAN_API_KEY=

# Deployed contract addresses (populated after running DeployAll.s.sol)
POOL_MANAGER_ADDRESS=
VAULT_ADDRESS=
YIELD_VAULT_ADDRESS=
HOOK_ADDRESS=
SCENARIO_RUNNER_ADDRESS=

# Reactive Network callback proxy on Unichain Sepolia
CALLBACK_PROXY_ADDRESS=0x9299472A6399Fd1027ebF067571Eb3e3D7837FC4
